PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/voo-ai

JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=your_google_client_id

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview
AI_PROVIDER=groq

# Password reset emails (see lib/email.js). EMAIL_PROVIDER=sendgrid is the only
# one wired up right now; "ses" is a stub for later.
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@voo-ai.app
EMAIL_FROM_NAME=Voo AI
